# Auto detect text files and normalize line endings to LF
* text=auto

# JSON files
*.json text eol=lf
*.jsonc text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JavaScript
*.js text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf
